STYLE_SETTINGS_BODY_CLASSES=theme-dark mod-windows is-frameless is-hidden-frameless obsidian-app styled-scrollbars show-inline-title is-floating-nav auto-full-screen show-ribbon is-maximized folder-notes-plugin hide-folder-note fn-hide-empty-collapse-icon folder-note-underline folder-note-bold folder-note-underline-path fn-hide-collapse-icon fn-ignore-attachment-folder version-1-7-2 css-settings-manager uw-ocean rose-pine-dawn callout-solid table-minimal normal Moon no-activeline no-scrollbar no-calendar is-focused
